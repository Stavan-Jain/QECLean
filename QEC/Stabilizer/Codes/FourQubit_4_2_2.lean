  -- TODO(stab_4_2_2-T8a): operator-level anticommute; use commutes_iff_even_anticommutes
  -- contrapositive with hfilter = {3} (cardinality 1, odd).

/-- `X̄₂` and `Z̄₂` anticommute (overlap at qubit 3 only — odd parity). -/
