/-- `seamC` is additive, so it kills `0`. -/
theorem seamC_zero : seamC 0 = 0 := by
  have h : seamC 0 + seamC 0 = seamC 0 + 0 := by rw [← seamC_add, add_zero, add_zero]
  exact add_left_cancel h

/-- The all-zero `kcombo` is the zero class. -/
theorem kcombo_zero : kcombo 0 0 0 0 0 0 = 0 := by funext h; simp [kcombo]

/-- The two values of `ZMod 2` (case-split with literal substitution). -/
theorem zmod2_cases (c : ZMod 2) : c = 0 ∨ c = 1 := by revert c; decide

