  intro ζ hζ f hb
  have h : ζ = kcombo (ζ (4,4)) (ζ (4,5)) (ζ (5,2)) (ζ (5,3)) (ζ (5,4)) (ζ (5,5)) :=
    (kerBasis_spans ζ hζ).symm.trans (recon_eq_kcombo ζ)
  rw [h] at hb ⊢
  exact floor_kcombo (ζ (4,4)) (ζ (4,5)) (ζ (5,2)) (ζ (5,3)) (ζ (5,4)) (ζ (5,5)) f hb

