/-- `ε(A) = 1`. -/
lemma epsA_holds : ∑ h : G84, az6z14 h = 1 := by native_decide

/-- `ε(B) = 1`. -/
lemma epsB_holds : ∑ h : G84, bz6z14 h = 1 := by native_decide

/-- No normalized weight-2 cycle. -/
lemma check_two_holds : ∀ b : Fin 2, ∀ q : G84 × Fin 2,
    q ≠ ((0 : G84), b) →
    ∃ h : G84, SmallCycle.termAt az6z14 bz6z14 ((0 : G84), b) h
      + SmallCycle.termAt az6z14 bz6z14 q h ≠ 0 := by
  native_decide

/-- No normalized weight-4 cycle (tuple form; colliding tuples cancel to
the weight-2 shape). -/
lemma check_four_holds : ∀ b : Fin 2, ∀ q₁ q₂ q₃ : G84 × Fin 2,
    q₁ = ((0 : G84), b) ∨ q₂ = ((0 : G84), b) ∨
    q₃ = ((0 : G84), b) ∨
    ∃ h : G84, SmallCycle.termAt az6z14 bz6z14 ((0 : G84), b) h
      + SmallCycle.termAt az6z14 bz6z14 q₁ h
      + SmallCycle.termAt az6z14 bz6z14 q₂ h
      + SmallCycle.termAt az6z14 bz6z14 q₃ h ≠ 0 := by
  native_decide

/-- The small-cycle bundle: the four finite obligations, machine-checked. -/
def floorData : SmallCycleData G84 where
  A := az6z14
  B := bz6z14
  epsA := epsA_holds
  epsB := epsB_holds
  check_two := check_two_holds
  check_four := check_four_holds

lemma floorData_complex : floorData.complex = z6z14Complex := rfl

/-- **Strong small-cycle floor**: every nonzero 1-cycle of the bb_z6z14
complex has weight ≥ 6 — boundaries included. -/
theorem strong_floor (u : G84 × Fin 2 → ZMod 2)
    (hcyc : bbBoundary1Fn az6z14 bz6z14 u = 0) (hne : u ≠ 0) :
    6 ≤ (Finset.univ.filter fun p => u p ≠ 0).card :=
  floorData.cycle_weight_ge_6 u hcyc hne

/-- Chain-level d ≥ 6 on nontrivial cycles. -/
theorem chain_floor :
    ∀ u ∈ z6z14Complex.cycles, u ∉ z6z14Complex.boundaries →
      6 ≤ z6z14Complex.chainWeight u :=
  floorData.chain_floor

/-- Dual-side chain floor (via the Φ duality). -/
theorem dual_chain_floor :
