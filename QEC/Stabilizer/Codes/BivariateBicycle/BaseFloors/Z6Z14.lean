namespace Z6Z14

/-- The group `Z6 × Z14`. -/
abbrev G84 : Type := ZMod 6 × ZMod 14

/-- `A = 1 + y + x^3*y^3`. -/
def az6z14 : G84 → ZMod 2 := fun g =>
  if g = (0, 0) ∨ g = (0, 1) ∨ g = (3, 3) then 1 else 0

/-- `B = 1 + x + x^2*y^7`. -/
def bz6z14 : G84 → ZMod 2 := fun g =>
  if g = (0, 0) ∨ g = (1, 0) ∨ g = (2, 7) then 1 else 0

/-- The bb_z6z14 chain complex. -/
noncomputable def z6z14Complex : HomologicalCode := bbChainComplex az6z14 bz6z14

theorem z6z14Complex_numQubits : z6z14Complex.numQubits = 168 := by
  change bbNumQubits G84 = 168
  unfold bbNumQubits
  rw [Fintype.card_prod, ZMod.card, ZMod.card]

/-! The four finite obligations, one declaration each (each `native_decide`
